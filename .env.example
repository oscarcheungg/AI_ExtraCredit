# Copy to .env.local and fill in your values.
# OpenAI: https://platform.openai.com/api-keys
# EXA: https://exa.ai/ | Pinecone: https://app.pinecone.io/

# OpenAI – chat model (required)
OPENAI_API_KEY=

# EXA – web search tool
EXA_API_KEY=

# Pinecone – vector database search tool (index name is set in config.ts as PINECONE_INDEX_NAME)
PINECONE_API_KEY=
